<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 添加必要的权限 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication"
        android:name=".MyApplication"
        tools:targetApi="31">
        
        <!-- 启动界面 -->
        <activity
            android:name="com.poopblock.russian.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication.NoActionBar"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- 主菜单界面 -->
        <activity
            android:name="com.poopblock.russian.MainMenuActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        
        <!-- 关于页面 -->
        <activity
            android:name="com.poopblock.russian.AboutActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
            
        <!-- 设置页面 -->
        <activity
            android:name="com.poopblock.russian.SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
            
        <!-- 游戏页面 -->
        <activity
            android:name="com.poopblock.russian.GameActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        
        <!-- 游戏记录页面 -->
        <activity
            android:name="com.poopblock.russian.GameRecordActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        
        <!-- 音乐播放服务 -->
        <service
            android:name="com.poopblock.russian.MusicService"
            android:exported="false" />
    </application>

</manifest>
