<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include the shared preferences and database -->
        <include domain="sharedpref" path="" />
        <include domain="database" path="" />
        <!-- Exclude the cache -->
        <exclude domain="cache" path="" />
    </cloud-backup>
    <device-transfer>
        <!-- Include the shared preferences and database -->
        <include domain="sharedpref" path="" />
        <include domain="database" path="" />
        <!-- Exclude the cache -->
        <exclude domain="cache" path="" />
    </device-transfer>
</data-extraction-rules>
